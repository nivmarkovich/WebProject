# ===========================
# Auth Server (port 4000)
# ===========================
AUTH_PORT=4000
ACCESS_TOKEN_SECRET=your-access-token-secret-here-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here-change-in-production
CORS_ORIGIN=http://localhost:3000

# ===========================
# PostgreSQL
# ===========================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=lora_defi

# ===========================
# MongoDB
# ===========================
MONGODB_URI=mongodb://localhost:27017/lora_defi

# ===========================
# OpenRouteService
# ===========================
ORS_API_KEY=your-openrouteservice-api-key-here

# ===========================
# Next.js (port 3000)
# ===========================
NEXT_PUBLIC_AUTH_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_MAP_DEFAULT_LAT=32.0853
NEXT_PUBLIC_MAP_DEFAULT_LNG=34.7818
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=13
